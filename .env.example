# ============================================================
# Aurix - Environment Configuration
# Copy this file to `.env` and fill in real values.
# Never commit .env to source control.
# ============================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=aurix.settings.development
SECRET_KEY=change-me-in-production-min-50-chars-of-entropy
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (production uses Postgres; dev falls back to SQLite if blank) ---
DATABASE_URL=postgres://aurix:aurix@db:5432/aurix

# --- Redis cache (used by price service + rate limiting) ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=7

# --- Gold price feed ---
# Pick ONE provider. Recommended: stooq (free, no API key, very reliable).
# Options:
#   stooq      - https://stooq.com  (default; free public CSV, no key)
#   yfinance   - Yahoo Finance via the yfinance package; no API key.
#               Often rate-limited from cloud IPs.
#   mock       - hardcoded price; deterministic; useful for tests.
#   goldapi    - https://www.goldapi.io       (requires GOLDAPI_KEY)
#   metalsdev  - https://metals.dev            (requires METALSDEV_KEY)
PRICE_PROVIDER=stooq
PRICE_CACHE_TTL_SECONDS=60

# GoldAPI.io (https://www.goldapi.io) - free tier, returns XAU in any currency
GOLDAPI_KEY=
GOLDAPI_BASE_URL=https://www.goldapi.io/api

# Metals.dev (https://metals.dev) - alt provider
METALSDEV_KEY=

# Mock fallback price (EUR per gram). Used when PRICE_PROVIDER=mock.
MOCK_GOLD_PRICE_EUR_PER_GRAM=65.00

# --- AI insights (optional, falls back to rule engine if absent) ---
INSIGHT_ENGINE=rule              # rule | llm
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- CORS (frontend origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Observability ---
SENTRY_DSN=
